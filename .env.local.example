# Supabase Configuration (REQUIRED)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Paystack Configuration (for payment processing)
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
# In production set this to https://otters.ke/api/paystack/callback (canonical host only).
PAYSTACK_CALLBACK_URL=https://your-domain.vercel.app/api/paystack/callback

# Application Configuration — always use ONE canonical URL in production:
# https://otters.ke   (preferred host for NEXT_PUBLIC_APP_URL, Supabase Site URL, email links).
# Point otters.co.ke → otters.ke with a redirect at Vercel/DNS so both work in the browser but
# env vars and auth configuration stay on otters.ke only.
# Must match Supabase Auth → Redirect URL allowlist + /auth/callback, finish-invite, etc.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Coach pay cron (Vercel Cron hits /api/cron/coach-session-pay with this bearer token)
COACH_PAY_CRON_SECRET=generate_a_long_random_string

# Wall-clock zone for training_sessions.session_date + end_time (IANA)
APP_TIMEZONE=Africa/Nairobi

# Optional: BCC-style admin/finance address for coach session pay emails (logged until SMTP2GO)
COACH_PAY_NOTIFY_EMAIL=
